# ─── Backend ─────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ─── Database (PostgreSQL) ───────────────────────────────
# Host port from docker-compose.dev.yml: 5442
# DATABASE_URL_MIGRATIONS — runs with BYPASSRLS role (used by Prisma migrate)
# DATABASE_URL — runtime connection (uses RLS-restricted role app_user, set in phase B.2)
# Migrations use the superuser (BYPASSRLS by default).
DATABASE_URL_MIGRATIONS=postgresql://postgres:postgres@localhost:5442/kars_hotel?schema=public
# Runtime uses app_user (NOSUPERUSER NOBYPASSRLS) — see prisma migration b2_rls_policies.
DATABASE_URL=postgresql://app_user:app_user_dev_pwd@localhost:5442/kars_hotel?schema=public

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6380

# ─── MinIO (S3-compatible) ───────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=kars-hotel
# Public base for serving uploaded media (room-type photos) by URL — partners
# (e.g. Kars Avia) fetch these via <img src>. Defaults to S3_ENDPOINT. In prod
# point this at a public host/CDN fronting the bucket.
S3_PUBLIC_URL=http://localhost:9000

# ─── Mail (Mailhog in dev) ───────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM="KarsHotel PMS <no-reply@karshotel.local>"

# ─── Auth / JWT (will be used in phase B) ────────────────
JWT_ACCESS_SECRET=dev-access-secret-change-me-in-prod
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-in-prod
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=10
